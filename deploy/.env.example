# Copy to .env on the SERVER — never commit .env. Keys stay on the server only.
# Required for live ASR/TTS (server must reach api.sarvam.ai + api.elevenlabs.io).

# --- Secrets (REQUIRED for live calls) ---
SARVAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Carrier / pipeline ---
CARRIER=asterisk
ASR_ENABLED=true
TTS_ENABLED=true
ASR_LANGUAGE=en-IN
TARGET_SAMPLE_RATE=16000
TTS_OUTPUT_FORMAT=pcm_24000

# --- Brain (compose service name) ---
BRAIN_WS_ENABLED=true
BRAIN_WS_URL=ws://brain:8000/ws/brain

# --- Workers (compose DNS names; set ENABLED=false to passthrough) ---
DENOISE_ENABLED=false
DENOISE_ADDR=denoise:9091
AMD_ENABLED=false
AMD_ADDR=amd:9092
WHISPER_MODEL=tiny
SEMANTIC_TURN_ENABLED=true
SEMANTIC_TURN_ADDR=semantic-turn:9093
SEMANTIC_TURN_TIMEOUT_MS=500

# --- Server ---
LISTEN_ADDR=:8080
METRICS_ENABLED=true
EGRESS_PACING=realtime
BARGEIN_ENABLED=true

# --- Optional ---
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# SARVAM_ENDPOINT=
# AMD_TIMEOUT_MS=4000

# --- Redis (reserved; brain uses in-memory stub by default) ---
# REDIS_URL=redis://redis:6379
