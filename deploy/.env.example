# Copy to .env on the SERVER — never commit .env. Keys stay on the server only.
# Required for live ASR/TTS (server must reach api.sarvam.ai + api.elevenlabs.io).

# --- Secrets (REQUIRED for live calls) ---
SARVAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Carrier / pipeline ---
CARRIER=asterisk
ASR_ENABLED=true
TTS_ENABLED=true
ASR_LANGUAGE=hi-IN
TARGET_SAMPLE_RATE=16000
# Leave empty for asterisk — session_start output_sample_rate picks pcm_16000 vs pcm_24000.
TTS_OUTPUT_FORMAT=

# --- Brain (compose service name) ---
BRAIN_WS_ENABLED=true
BRAIN_WS_URL=ws://brain:8000/ws/brain

# --- Brain live mode (Collection engine) — defaults below keep STUB packaging working ---
# For real collections conversation set ALL of:
#   STUB_MODE=false
#   LLM_STUB=false
#   KB_STUB=false
STUB_MODE=true
LLM_STUB=true
KB_STUB=true
TOOLS_MODE=stub

# Vertex / Gemini (required when LLM_STUB=false)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GEMINI_MODEL_ID=gemini-2.5-flash
# Path INSIDE the brain container (must match docker-compose mount target).
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json
# Path ON THE HOST to the service-account JSON (chmod 600). Required for live brain.
GCP_CREDENTIALS_HOST_PATH=/root/fonada-voice/secrets/vertex-sa.json

# Fonada KB (required when KB_STUB=false)
KB_BASE_URL=https://api.fonada.ai
KB_API_KEY=
KB_SEARCH_PATH=/search
KB_TOP_K=10
KB_VERIFY_SSL=true

# --- Compliance call window (brain / Collection gate) ---
# Production default in engine: 08:00–19:00 Asia/Kolkata. Outside window → silent_reply "" (no TTS).
# TEMP TESTING (24h): uncomment the three lines below, recreate brain, revert after pilot sign-off.
# CALL_WINDOW_START=00:00
# CALL_WINDOW_END=23:59
# CALL_WINDOW_TIMEZONE=Asia/Kolkata

# Optional: Upstash for durable call state when STUB_MODE=false (else in-memory stub)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Local Postgres (borrower lookup for test calls — NOT Supabase/managed DB) ---
# Brain reads borrowers by phone; conversation state stays in memory stub unless Upstash set.
POSTGRES_USER=collections
POSTGRES_PASSWORD=
POSTGRES_DB=collections
# Set in brain container via compose; override only if running brain outside compose:
# BORROWER_DATABASE_URL=postgresql://collections:YOUR_PASSWORD@postgres:5432/collections

# --- Endpointing (go-server turn manager) ---
# Default silence ms after ASR final + speech_end (per flow class).
# SILENCE_MS_YESNO=400
# SILENCE_MS_DEFAULT=850
# SILENCE_MS_SPELLED=1200
# Extra wait for 1–2 word fragments (names spoken with a mid-word pause).
# SILENCE_MS_SHORT_FRAGMENT=950

# --- Dead-air watchdog (go-server) ---
# Real Gemini + ElevenLabs first chunk is slower than stub; default 7000ms avoids
# premature "ek minute" holding line. Watchdog still fires on genuine dead air.
FALLBACK_NO_AUDIO_MS=7000
# HOLDING_LINE=ek minute

# --- Workers (compose DNS names; set ENABLED=false to passthrough) ---
DENOISE_ENABLED=false
DENOISE_ADDR=denoise:9091
AMD_ENABLED=false
AMD_ADDR=amd:9092
WHISPER_MODEL=tiny
SEMANTIC_TURN_ENABLED=true
SEMANTIC_TURN_ADDR=semantic-turn:9093
SEMANTIC_TURN_TIMEOUT_MS=500

# --- Server ---
LISTEN_ADDR=:8080
METRICS_ENABLED=true
EGRESS_PACING=realtime
BARGEIN_ENABLED=true

# --- Optional ---
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# SARVAM_ENDPOINT=
# AMD_TIMEOUT_MS=4000

# --- Redis (reserved) ---
# REDIS_URL=redis://redis:6379
