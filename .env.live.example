# Live stack config (no secrets). Copy to .env.live and adjust.
# API keys go in .env only — never commit .env / .env.local / .env.live

ASR_ENABLED=true
TTS_ENABLED=true
BRAIN_WS_ENABLED=true
BRAIN_WS_URL=ws://127.0.0.1:8000/ws/brain

AMD_ENABLED=true
DENOISE_ENABLED=true
SEMANTIC_TURN_ENABLED=true

CARRIER=fonada
EGRESS_PACING=realtime
METRICS_ENABLED=true

LISTEN_ADDR=:8080
AMD_TIMEOUT_MS=4000
WHISPER_MODEL=tiny

# Optional overrides
# SARVAM_ENDPOINT=wss://api.sarvam.ai/speech-to-text/ws
# ASR_MODEL=saaras:v3
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
